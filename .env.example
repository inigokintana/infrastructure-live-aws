# AWS Infrastructure Live Environment Variables
# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env to git!

# AWS Credentials
export AWS_ACCESS_KEY_ID=your-access-key-id
export AWS_SECRET_ACCESS_KEY=your-secret-access-key
export AWS_REGION=us-east-1

# Terraform Backend Configuration
# S3 bucket will be created as: terragrunt-state-{account-name}-{region}
export TG_BUCKET_PREFIX=my-company

# Optional: DynamoDB for state locking (must be created manually)
# Format: tf-locks (hardcoded in root.hcl, can be customized there)

# Optional: Enable debug logging
# export TF_LOG=DEBUG
